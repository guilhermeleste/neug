// CROSS PRODUCT

MATCH (a:person), (b:person) WHERE a.ID = b.ID AND a.ID = 7 RETURN a.fName, b.fName, a.grades, b.grades; # A_MATCH_B_1

MATCH (a:person), (b:person) WHERE a.age = b.age AND a.eyeSight = b.eyeSight AND a.lastJobDuration = b.lastJobDuration AND a.ID > 7 RETURN a.fName, b.fName; # A_MATCH_B_2

MATCH (a), (b) WHERE a.name = b.name AND a.length = b.length AND a.note = b.note RETURN a.description, b.description; # A_MATCH_B_3

MATCH (a:person), (b:person) WHERE a.courseScoresPerTerm = b.courseScoresPerTerm AND a.ID = b.ID RETURN SUM(a.ID); # A_MATCH_B_4

MATCH (a:person)-[e1:knows]->(b:person) , (c:person)-[e2:knows]->(d:person) WHERE a.ID = 0 AND c.ID = 2 AND e1.date = e2.date RETURN id(e1), e1.date, id(e2), e2.date; # AB_CD_9

// REGULAR MATCH

MATCH (a:person) WHERE a.gender = 1 WITH a AS k MATCH (k)-[e:knows]->(b:person) WHERE b.gender = 2 RETURN COUNT(*); # A_MATCH_KB_10

// OPTIONAL MATCH

MATCH (a:person) OPTIONAL MATCH (a)-[:knows]->(b:person) WHERE b.age > a.age RETURN COUNT(*); # A_OPTIONAL_AB_11

MATCH (a:person)-[:knows]->(b:person) OPTIONAL MATCH (b)-[:knows]->(c:person) WHERE c.age > b.age RETURN COUNT(*); # AB_OPTIONAL_BC_12

MATCH (a:person)-[:knows]->(b:person) OPTIONAL MATCH (a)-[:knows]->(c:person), (b)-[:knows]->(c) RETURN COUNT(*); # AB_OPTIONAL_ABC_13

// MATCH (a)-[]->(b) WHERE a.ID = 0 OPTIONAL MATCH (c:person) WHERE c.ID = b.ID + 3 RETURN a.ID, b.ID, c.ID; # AB_OPTIONAL_C_14

MATCH (a:person) WHERE a.fName = 'Alice' OPTIONAL MATCH (b:person) WHERE b.fName = 'A' RETURN a.ID, b.ID; # A_OPTIONAL_B_15

MATCH (a:organisation) OPTIONAL MATCH (a)<-[:knows|:studyAt]-(b:person) RETURN COUNT(*); # A_OPTIONAL_AB_16

MATCH (a:organisation:person) OPTIONAL MATCH (a)-[:studyAt|:workAt]->(b:person:organisation) RETURN COUNT(*); # A_OPTIONAL_AB_17

OPTIONAL MATCH (a:person) WHERE a.fName = 'a' MATCH (b:person) WHERE b.fName = 'Alice' RETURN a.ID, b.ID; # OPTIONAL_A_MATCH_B_18

OPTIONAL MATCH (a:person) WHERE a.ID<0 RETURN COUNT(*); # OPTIONAL_A_19

OPTIONAL MATCH (a:person) WHERE a.fName = 'a' RETURN a.age; # OPTIONAL_A_20

MATCH (a:person)-[:knows]->(b:person) WHERE a.ID=0 OPTIONAL MATCH (a)-[:knows]->(c:person), (b)-[:knows]->(c) RETURN COUNT(*); # AB_OPTIONAL_ABC_21

MATCH (a:person)-[:knows]->(b:person) OPTIONAL MATCH (a)-[:studyAt]->(c:organisation), (b)-[:studyAt]->(c) RETURN COUNT(*); # AB_OPTIONAL_ABC_22

MATCH (a:person) OPTIONAL MATCH (a)-[:knows]->(b:person) MATCH (b)-[:knows]->(c:person) RETURN COUNT(*); # A_OPTIONAL_AB_MATCH_BC_23

MATCH (a:person) OPTIONAL MATCH (a)-[:knows]->(b:person) MATCH (b)-[:studyAt]->(c:organisation) RETURN COUNT(*); # A_OPTIONAL_AB_MATCH_BC_24

MATCH (a:person) OPTIONAL MATCH (a)-[:knows]->(b:person) WHERE b.fName='Farooq' MATCH (b)<-[:knows]-(c:person) RETURN COUNT(*); # A_OPTIONAL_AB_MATCH_BC_25

match (a:person)-[:knows]->(b:person) optional match (a)-[:knows]->(c:person) match (b)-[:knows]->(c) return count(*); # AB_OPTIONAL_AC_MATCH_BC_26

MATCH (a:person)-[:knows]->(b:person) OPTIONAL MATCH (b)-[:knows]->(c:person) MATCH (c)-[:knows]->(d:person)-[:knows]->(e:person) RETURN COUNT(*); # AB_OPTIONAL_BC_MATCH_CDE_27

MATCH (a:person) WHERE a.fName='Elizabeth' OR a.fName='Hubert Blaine Wolfeschlegelsteinhausenbergerdorff' OPTIONAL MATCH (a)-[:knows]->(b:person) RETURN a.fName, b.fName; # A_OPTIONAL_AB_28

MATCH (a:person)-[:knows]->(b:person) WHERE a.fName='Alice' OPTIONAL MATCH (b)-[:studyAt]->(c:organisation) RETURN c.orgCode; # AB_OPTIONAL_BC_29

MATCH (a:person) OPTIONAL MATCH (a)-[:knows]->(b:person) WHERE b.fName='Farooq' RETURN a.fName, b.fName; # A_OPTIONAL_AB_30

MATCH (a:person) OPTIONAL MATCH (a)-[:knows]->(b:person) OPTIONAL MATCH (b)-[:knows]->(c:person) RETURN COUNT(*); # A_OPTIONAL_AB_OPTIONAL_BC_34

Match (a:person)-[:knows*2..3]->(c:person) Where NOT (a)-[:knows]->(c) Return count(a); # WHERE_SUBQUERY

Match (a:person)-[:knows*2..3]->(c:person) Where (a)-[:knows]->(c) Return count(a); # WHERE_NOT_SUBQUERY
