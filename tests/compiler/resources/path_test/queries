MATCH (a:person)-[:knows*1..2]->(b:person) WHERE a.ID = 7 RETURN b.name; # KNOWS_1_2
MATCH (a:person)-[e:knows*1..2 (r,_ | WHERE r.weight > 1.0)]->(b:person) WHERE a.name = 'Alice' AND b.name = 'Bob' RETURN e; # KNOWS_1_2_FILTER 
MATCH (a:person)-[:knows_v2*1..2]->(b:person) WHERE a.ID = 7 RETURN b.name; # KNOWS_V2_1_2
MATCH (a:person)-[e:knows*3..3]->(b:person) RETURN COUNT(b.name); # KNOWS_3_3
MATCH (a:person)-[e:knows* TRAIL 2..3]->(b:person) RETURN COUNT(b.name); # TRAIL_Path
MATCH (a:person)-[e:knows* ACYCLIC 2..3]->(b:person) RETURN COUNT(b.name); # ACYCLIC_Path
MATCH (p: person {id : 1}) -[k:knows* SHORTEST 1..4]-(f:PERSON {name : 'lion'}) RETURN k; # ANY_SHORTEST_Path
MATCH (a:person)-[e:knows* ALL SHORTEST 1..3]->(b:person) RETURN COUNT(b.name); # ALL_SHORTEST_Path
Match (a:person)-[b:knows]-(c:person) Return START_NODE(b) as n1, END_NODE(b) as n2; # START_NODE
Match (a:person)-[b:knows*1..3]-(c:person) Return length(b) as len # Length
Match (a:person)-[b:knows*1..3]-(c:person) Return nodes(b) as n1, rels(b) as n2 # Nodes
Match (a:person)-[b:knows*1..3]-(c:person) Return properties(nodes(b), 'name') as n1, properties(rels(b), 'weight') as n2 # Properties

