MATCH (p1:person)-[:knows]-(:person)-[:knows]-(p2:person)-[:person_islocatedin]->(pl:place) WHERE p1.p_personid = 933 AND p2.p_firstname = "Boris" RETURN p2.p_personid as p2_id, p2.p_lastname as p2_lastname, p2.p_birthday as p2_birthday, p2.p_creationdate as p2_creationdate, p2.p_gender as p2_gender, p2.p_browserused as p2_browserused, p2.p_locationip as p2_locationip, pl.pl_name as pl_name
