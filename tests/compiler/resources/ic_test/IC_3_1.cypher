MATCH (p1:person)-[k1:knows]-(p2:person)<-[:comment_hascreator]-(m1:comment)-[:comment_islocatedin]->(pl1:place), (p2)<-[:comment_hascreator]-(m2:comment)-[:comment_islocatedin]->(pl2:place) WHERE p1.p_personid = 933 AND m1.m_creationdate >= 1346770795431 AND m1.m_creationdate < 1348066795431 AND m2.m_creationdate >= 1346770795431 AND m2.m_creationdate < 1348066795431 AND pl1.pl_name = "Turkey" AND pl2.pl_name = "Turkey" RETURN p2.p_personid as p2_id, p2.p_firstname as p2_firstname, p2.p_lastname as p2_lastname
