MATCH (n:person) return n.name; # SCAN
Match (n:person) Where n.id = 1 Return n; # SCAN_FILTER
Match (n:person)-[f:knows]->(m:person) Return n.name, f, m.name; # EXPAND 
Match (n:person)-[f:knows]->(m:person) Where n.id = 1 AND f.weight > 10.0 Return n.name, f, m.name; # EXPAND_FILTER
Match (n:person)-[f:knows]->(m:person) Where n.id = 1 AND f.weight > 10.0 AND m.name = 'cc' Return n.name, f.weight, m.name; # GETV_FILTER 
Match (:person {name: "mark"})-[:knows {weight: 10.0}]->(m:person) Return m; # EXPAND_FILTER_2
Match (:person {name: "mark"})-[:knows {weight: 10.0}]->(m:person) Return m as q; # PROJECT_AS 
MATCH (a:person)-[:knows]->(:person)-[:knows]->(b:person) WHERE a.age>b.age+10 RETURN a.age, b.age; #FILTER
