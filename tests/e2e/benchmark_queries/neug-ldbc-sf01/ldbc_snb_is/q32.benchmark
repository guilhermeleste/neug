-NAME q32
-QUERY MATCH (n:PERSON)-[:ISLOCATEDIN]->(p:PLACE) WHERE n.id = 1129 RETURN n.firstName AS firstName, n.lastName AS lastName,n.birthday AS birthday, n.locationIP AS locationIP, n.browserUsed AS browserUsed,p.id AS cityId,n.gender AS gender,n.creationDate AS creationDate
