-DATASET CSV tinysnb

--

-CASE CastTest

-LOG int32_int32
-STATEMENT RETURN CAST(CAST(888, "INT32"), "INT32")
---- 1
888

-LOG int32_uint32
-STATEMENT RETURN CAST(CAST(888, "INT32"), "UINT32")
---- 1
888

-LOG int32_uint32
-STATEMENT RETURN CAST(CAST(-888, "INT32"), "UINT32")
---- error
Overflow exception: Value -888 is not within UINT32 range.

-LOG int32_int64
-STATEMENT RETURN CAST(CAST(-888, "INT32"), "INT64")
---- 1
-888

-LOG int32_uint64
-STATEMENT RETURN CAST(CAST(-888, "INT32"), "UINT64")
---- error
Overflow exception: Value -888 is not within UINT64 range.

-LOG int32_float
-STATEMENT RETURN CAST(CAST(-888, "INT32"), "FLOAT")
---- 1
-888

-LOG int32_double
-STATEMENT RETURN CAST(CAST(-888, "INT32"), "DOUBLE")
---- 1
-888




