-LOG DivideDECIMAL
-STATEMENT UNWIND [0.6, 1.2, -100.0] as A UNWIND [-0.2, 1.2, 100.5] AS B RETURN CAST(A, 'DECIMAL') / CAST(B, 'DECIMAL');
