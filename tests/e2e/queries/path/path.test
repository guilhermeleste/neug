-DATASET CSV comprehensive_graph

--

-CASE TestPathExpand
-LOG TestSLODPathExpand
-STATEMENT MATCH (v:node_a)-[:rel_a*0..1]->(v2:node_a) where v.id=1 RETURN v2.id
---- 3
1
7
4
-LOG TestSLBDPathExpand
-STATEMENT MATCH (v:node_a)-[:rel_a*0..1]-(v2:node_a) where v.id=1 RETURN v2.id
---- 3
1
7
4
-LOG TestSLIDPathExpand
-STATEMENT MATCH (v:node_a)<-[:rel_a*0..1]-(v2:node_a) where v.id=1 RETURN v2.id
---- 1
1
-LOG TestMLODPathExpand
-STATEMENT MATCH (v:node_a)-[:rel_a|rel_b*0..1]->(v2:node_a:node_b) where v.id=1 RETURN v2.id,label(v2)
---- 5
1|node_a
7|node_a
4|node_a
7|node_b
4|node_b
-LOG TestMLBDPathExpand
-STATEMENT MATCH (v:node_a)-[:rel_a|rel_b*0..1]-(v2:node_a:node_b) where v.id=1 RETURN v2.id,label(v2)
---- 5
1|node_a
7|node_a
4|node_a
7|node_b
4|node_b
-LOG TestMLIDPathExpand
-STATEMENT MATCH (v:node_a)<-[:rel_a|rel_b*0..1]-(v2:node_a:node_b) where v.id=1 RETURN v2.id,label(v2)
---- 1
1|node_a

