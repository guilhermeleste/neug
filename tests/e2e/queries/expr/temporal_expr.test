-DATASET CSV tinysnb

-- 

--CASE DataExprTest

-LOG TestDataPartMonthOnDate
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN date_part("month", n.birthdate)
---- 1
1

-LOG TestDataPartYearOnDate
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN date_part("year", n.birthdate)
---- 1
1900

-LOG TestReturnDate
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN n.birthdate
---- 1
1900-01-01


-LOG TestReturnTimestamp
-SKIP: No timestamp field.
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN n.timestamp_field
---- 1
1234566

-LOG TestReturnDateTime
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN n.registerTime
---- 1
2011-08-20 11:25:30.000

-LOG TestReturnInterval
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN n.lastJobDuration
---- 1
3 years 2 days 13 hours 2 minutes


-LOG TestReturnSecondDatetime
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN date_part('second', n.registerTime)
---- 1
30

-LOG TestReturnYearInterval
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN date_part('year', n.lastJobDuration)
---- 1
3

-LOG TestDatePlusInterval
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN n.birthdate + n.lastJobDuration
---- 1
1903-01-03

-LOG TestDateMinusInterval
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN n.birthdate - n.lastJobDuration
---- 1
1896-12-29

-LOG TestDateTimeMinusInterval
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN n.registerTime - n.lastJobDuration
---- 1
2008-08-17 22:23:30.000

-LOG TestIntervalMinusInterval
-SKIP: interval minus interval is not supported
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN n.lastJobDuration - INTERVAL('1 hours')
---- 1
3 years 2 days 12 hours 2 minutes

-LOG TestDateMinusDate
-STATEMENT MATCH(n: person) WHERE n.ID = 0 RETURN n.birthdate - date('1899-01-01')
---- 1
8760 hours
