-LOG IS4
-STATEMENT MATCH (m:POST:COMMENT {id: 1030792332314})
RETURN
    CASE WHEN m.content = "" THEN m.imageFile
    ELSE m.content END as messageContent,
    m.creationDate as messageCreationDate
