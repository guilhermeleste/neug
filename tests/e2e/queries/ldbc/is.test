-LOG IS5
-STATEMENT MATCH (m:POST : COMMENT {id: 1030792332314  })-[:HASCREATOR]->(p:PERSON)
RETURN
    p.id AS personId,
    p.firstName AS firstName,
    p.lastName AS lastName
---- 1
26388279066868|Patricia|Alvarez


-LOG IS6
# do not support [:REPLYOF*0..*], use [:REPLYOF*0..10] instead
-STATEMENT MATCH (m:POST : COMMENT {id:  1030792332314 })-[:REPLYOF*0..10]->(p:POST)<-[:CONTAINEROF]-(f:FORUM)-[:HASMODERATOR]->(mod:PERSON)
RETURN
    f.id AS forumId,
    f.title AS forumTitle,
    mod.id AS moderatorId,
    mod.firstName AS moderatorFirstName,
    mod.lastName AS moderatorLastName
