-LOG IC6
# Note: 1..2
-STATEMENT MATCH (p_:PERSON {id: 19791209300317})-[:KNOWS*1..2]-(other:PERSON)
WITH other, COUNT(other) as cnt
WHERE  other.id <> 19791209300317

MATCH (other)<-[:HASCREATOR]-(p:POST)-[:HASTAG]->(t:TAG {name: "Nat_King_Cole"})
MATCH    (p:POST)-[:HASTAG]->(otherTag:TAG)

WITH otherTag, t, p, COUNT(p) as cnt
WITH otherTag, t, count(p) as postCount
WHERE 
    otherTag <> t 
RETURN
    otherTag.name as tagName,
    postCount
ORDER BY 
    postCount desc, 
    tagName asc 
LIMIT 10;
