-LOG IC5
-SKIP: UNION has some bugs
-STATEMENT MATCH (person:PERSON { id: 4398046511592 })-[:KNOWS*1..2]-(friend)
WITH friend, COUNT(friend) as cnt
WHERE friend.id <> 4398046511592
CALL (friend) {
  WITH friend
  MATCH (friend)<-[membership:HASMEMBER]-(forum)
  WHERE membership.joinDate > TIMESTAMP("2012-09-02 00:00:00.000")
  WITH forum, COUNT(forum) as cnt
  ORDER BY forum.id ASC
  LIMIT 20
  RETURN forum, 0 AS postCount

UNION ALL

  WITH friend
  MATCH (friend)<-[membership:HASMEMBER]-(forum)
  WHERE membership.joinDate > TIMESTAMP("2012-09-02 00:00:00.000")
  MATCH (friend)<-[:HASCREATOR]-(post)<-[:CONTAINEROF]-(forum)
  WITH forum, count(post) AS postCount
  RETURN forum, postCount
  ORDER BY postCount DESC, forum.id ASC
  LIMIT 20
}
WITH forum, max(postCount) AS postCount
ORDER BY postCount DESC, forum.id ASC
LIMIT 20

RETURN forum.title as forumTitle, postCount;
