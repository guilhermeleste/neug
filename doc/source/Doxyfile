PROJECT_NAME = "NeuG C++ API"
PROJECT_NUMBER = "0.0.1"
PROJECT_BRIEF = "NeuG Graph Database C++ API Reference"

# Output configuration
OUTPUT_DIRECTORY = "build/html/reference"
HTML_OUTPUT = "cpp_api_doxygen"
XML_OUTPUT = "cpp_api_doxygen/xml"

# Input configuration
INPUT = ../include/neug
FILE_PATTERNS = *.h *.hpp
RECURSIVE = YES
EXCLUDE_PATTERNS = */test/* */tests/* *_test.h *_test.hpp

# Extraction settings
EXTRACT_ALL = YES
EXTRACT_STATIC = YES
EXTRACT_PRIVATE = NO
EXTRACT_PACKAGE = NO
EXTRACT_LOCAL_CLASSES = YES
EXTRACT_LOCAL_METHODS = NO
EXTRACT_ANON_NSPACES = NO

# Documentation settings
HIDE_UNDOC_MEMBERS = NO
HIDE_UNDOC_CLASSES = NO
HIDE_FRIEND_COMPOUNDS = YES
HIDE_IN_BODY_DOCS = NO
BRIEF_MEMBER_DESC = YES
REPEAT_BRIEF = YES
JAVADOC_AUTOBRIEF = YES
QT_AUTOBRIEF = NO
MULTILINE_CPP_IS_BRIEF = NO
ALWAYS_DETAILED_SEC = NO

# Output formats
GENERATE_HTML = YES
GENERATE_XML = YES
GENERATE_LATEX = NO

# XML settings for Breathe integration
XML_PROGRAMLISTING = YES
XML_NS_MEMB_FILE_SCOPE = NO

# HTML settings
HTML_EXTRA_STYLESHEET = 
HTML_EXTRA_FILES = 
HTML_COLORSTYLE_HUE = 220
HTML_COLORSTYLE_SAT = 100
HTML_COLORSTYLE_GAMMA = 80

# Source browsing
SOURCE_BROWSER = YES
INLINE_SOURCES = NO
STRIP_CODE_COMMENTS = YES

# Advanced settings
OPTIMIZE_OUTPUT_FOR_C = NO
OPTIMIZE_FOR_FORTRAN = NO
OPTIMIZE_OUTPUT_VHDL = NO
OPTIMIZE_OUTPUT_SLICE = NO

# Preprocessor settings
ENABLE_PREPROCESSING = YES
MACRO_EXPANSION = NO
EXPAND_ONLY_PREDEF = NO
SEARCH_INCLUDES = YES
INCLUDE_PATH = ../../include